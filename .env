## Ports
PORT_BACKEND=48090
PORT_FRONTEND=48091
PORT_VALIDATOR=48092
# in production environments, set this port to 443
#VITE_BACKEND_PORT=$PORT_BACKEND

## Component Version
CSAF_CHECKER_VERSION=3.5.1
CSAF_VALIDATOR_VERSION=2.0.25
APP_VERSION=0.2.0
# The expected checksum of the gocsaf tarball, used in production builds for verification
CSAF_SHA256=62995edf30703bed8c7fd2de4c5aec7692b47c8c66e5d8bdc04e6936b9185c60

## Scan Slots
SCAN_SLOTS=10

## Memory limit for the docker compose containers (Docker memory string, e.g. 500m), 0 for unlimited
BACKEND_MEMORY_LIMIT=500m
FRONTEND_MEMORY_LIMIT=400m
CSAF_VALIDATOR_MEMORY_LIMIT=150m
VALKEY_MEMORY_LIMIT=500m

## Timeout for csaf_checker in seconds, 0 for unlimited
CSAF_CHECKER_TIMEOUT=3600

## Default value for the maximum amount of verbose runtime output displayed at once
## Scan requests may overwrite this value
VERBOSE_OUTPUT_MAX_LINES_DEFAULT=10

## Maximum total byte size of runtime log stored per scan, 0 for unlimited
RUNTIME_LOG_MAX_BYTES=500000

## Caching
CACHE_TIMEOUT_SECONDS=604800
VALIDATOR_CACHE_RESULTS=1

## Task Options
TASK_PAUSE_TIME_MAX_BEFORE_RESET=100
TASK_PAUSE_TIME_INTERVAL=0.2
TASK_TIME_BEFORE_ORPHANED=50

## Linting Options
LINTER_SHELLCHECK_OPTS="-e SC1091 -e SC2048"

## Domain Blocklist
# DOMAIN_BLOCKLIST="example.com second.example.com"
DOMAIN_BLOCKLIST=""

## Extra networks to block (space-separated CIDRs, applied by make restrict-network)
# EXTRA_IPV4_BLOCKS="203.0.113.0/24 198.51.100.0/24"
# EXTRA_IPV6_BLOCKS="2001:db8::/32"

## Extend frontend footer
FOOTER_TEXT=""
